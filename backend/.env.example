# --- Gemini API Key ---
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server Port ---
# Railway/Render will inject this automatically. Leave as 3001 for local dev.
PORT=3001
